<div class="bg-white rounded-xl shadow-sm border hover:shadow-md transition h-full flex flex-col">

  <!-- Header -->
  <div class="p-3 border-b flex justify-between items-center">
    <div>
      <p class="text-sm font-semibold text-gray-800">
        <%= (memberShipStatus === "elite" || message.user_id == userId) ? message.username : "Anonymous" %>
      </p>
      <p class="text-xs text-gray-400">
<%= memberShipStatus === "elite" 
  ? new Date(message.created_at).toLocaleDateString('en-IN', {
      day: 'numeric',
      month: 'short',
      year: 'numeric'
    })
  : "****" 
%>      </p>
    </div>

    <% if(message.user_id == userId){ %>
      <div class="text-xs flex gap-2">
        <a href="/update-message?messageId=<%=message.id%>" class="text-blue-500 hover:underline">Edit</a>
        <a href="/delete?messageId=<%=message.id%>" class="text-red-500 hover:underline">Delete</a>
      </div>
    <% } %>
  </div>

  <!-- Content -->
  <div class="p-3 flex-1 flex flex-col">
    <h2 class="font-bold text-gray-900 mb-2">
      <%= message.title %>
    </h2>

    <p class="text-gray-700 text-sm leading-relaxed line-clamp-5">
      <%= message.message_text %>
    </p>
  </div>

</div>